" Attiva sintassi

" Abilita filetype detection + indent automatico
filetype plugin indent on

" Numeri di riga
" set number
" set relativenumber

" Evidenzia riga corrente
set cursorline

" Evidenzia matching parentesi
set showmatch

" Ricerca migliorata
set hlsearch
set incsearch
set ignorecase
set smartcase

" Indentazione smart
set autoindent
set smartindent
set tabstop=4
set shiftwidth=4
set expandtab

" Scroll più confortevole
set scrolloff=8

" Mostra invisibili (utile)
" set list
" set listchars=tab:»·,trail:·

